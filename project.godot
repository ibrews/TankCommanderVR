; Tank Commander VR — Quest 3 standalone (Godot 4.7-beta3, Mobile renderer)
; Render/XR config follows the proven Fort recipe in
; kb: intelligence/techniques/godot-metahuman-quest-standalone.md
; (Mobile renderer base value, scaling_3d_scale=1.0 always, no ASW, shadows off)

config_version=5

[application]

config/name="Tank Commander VR"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.7", "Mobile")
config/icon="res://icon.png"

[autoload]

Tune="*res://scripts/tune.gd"
Game="*res://scripts/game.gd"
Sfx="*res://scripts/audio.gd"
NetManager="*res://scripts/net.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=1280
window/size/resizable=true

[physics]

common/physics_ticks_per_second=72

[rendering]

renderer/rendering_method="mobile"
renderer/rendering_method.mobile="mobile"
textures/vram_compression/import_etc2_astc=true
anti_aliasing/quality/msaa_3d=1
anti_aliasing/quality/screen_space_aa=0
anti_aliasing/quality/use_taa=false
scaling_3d/mode=1
scaling_3d/scale=1.0
environment/defaults/default_clear_color=Color(0.55, 0.62, 0.72, 1)
lights_and_shadows/directional_shadow/size=2048

[xr]

openxr/enabled=true
openxr/default_action_map="res://openxr_action_map.tres"
openxr/reference_space=2
openxr/foveation_level=3
openxr/foveation_dynamic=false
shaders/enabled=true
openxr/extensions/hand_tracking=true
; The action map declares bindings for /interaction_profiles/ext/hand_interaction_ext
; (bare-hand pinch/grasp). Without this flag, Godot never requests XR_EXT_hand_interaction
; at xrCreateInstance, so suggesting bindings for that profile fails at runtime — and on
; this Quest 3S stack that failure appears to abort interaction-profile binding for EVERY
; profile in the action map (Touch controllers included), not just the hand one. Symptom:
; OpenXRInterface.get_action_sets() shows the set attached+active, but every tracker's
; get_tracker_profile() reads "/interaction_profiles/none" and has_pose() is false across
; the board, despite the physical controllers working fine in every other app.
openxr/extensions/hand_interaction_profile=true
openxr/extensions/meta/application_space_warp=false
; OpenXRFbRenderModel (XR_FB_render_model) is confirmed NOT supported on
; Quest 3S specifically (Khronos runtime extension matrix; corroborated by an
; invisible controller on real hardware 2026-07-02), so the code no longer
; uses it — controller_visual.gd drives a bundled MIT-licensed model instead.
; Left off to avoid requesting the unused com.oculus.permission.RENDER_MODEL.
openxr/extensions/meta/render_model=false
openxr/extensions/meta/hand_tracking_mesh=true
openxr/extensions/meta/hand_tracking_aim=true
